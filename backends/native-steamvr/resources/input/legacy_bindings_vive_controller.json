{
  "bindings": {
    "/actions/legacy": {
      "haptics": [
        {
          "output": "/actions/legacy/out/left_haptic",
          "path": "/user/hand/left/output/haptic"
        }
      ],
      "poses": [
        {
          "output": "/actions/legacy/in/Left_Pose",
          "path": "/user/hand/left/pose/raw"
        }
      ],
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/legacy/in/left_axis0_press"
            },
            "position": {
              "output": "/actions/legacy/in/left_axis0_value"
            }
          },
          "mode": "joystick",
          "path": "/user/joystick/0/input/joystick_left"
        },
        {
          "inputs": {
            "pull": {
              "output": "/actions/legacy/in/left_axis1_value"
            },
            "touch": {
              "output": "/actions/legacy/in/left_axis1_touch"
            }
          },
          "mode": "trigger",
          "path": "/user/hand/left/input/trigger"
        },
        {
          "inputs": {
            "click": {
              "output": "/actions/legacy/in/left_grip_press"
            }
          },
          "mode": "button",
          "path": "/user/hand/left/input/grip"
        }
      ]
    }
  },
  "controller_type": "maratron_treadmill",
  "description": "Maratron treadmill legacy bindings",
  "name": "Maratron Treadmill Legacy Bindings"
}
